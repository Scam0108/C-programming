#pragma config FOSC = HS    
#pragma config WDTE = OFF   
#pragma config PWRTE = OFF  
#pragma config BOREN = OFF 
#pragma config LVP = OFF    
#pragma config CPD = OFF    
#pragma config WRT = OFF    
#pragma config CP = OFF     

#include <xc.h>
#include <stdio.h>         
#include <ctype.h> // Added for tolower() function

// ============================================================================
// MACRO DEFINITIONS
// ============================================================================
#define _XTAL_FREQ   20000000   // 20 MHz Crystal Frequency
#define BAUD_RATE    9600       // UART Baud Rate
#define SPBRG_VAL    (((_XTAL_FREQ / 16) / BAUD_RATE) - 1)
#define MAX_BUFFER   50         // Maximum length of input string

// ============================================================================
// UART FUNCTIONS
// ============================================================================

// Initialize UART (Serial Communication)
void UART_Init(void) {
    TRISC6 = 0;          // TX pin is Output (RC6)
    TRISC7 = 1;          // RX pin is Input  (RC7)
    
    SPBRG = SPBRG_VAL;   // Set Baud Rate to 9600
    TXSTAbits.BRGH = 1;  // High Speed mode
    TXSTAbits.SYNC = 0;  // Asynchronous mode
    
    RCSTAbits.SPEN = 1;  // Enable Serial Port
    TXSTAbits.TXEN = 1;  // Enable Transmission
    RCSTAbits.CREN = 1;  // Enable Reception
}

// Send one character over UART
void UART_Write_Char(char data) {
    while (!TXSTAbits.TRMT); // Wait until transmit buffer is empty
    TXREG = data;            // Send character
}

// Send a full text string over UART
void UART_Write_String(char *str) {
    while (*str != '\0') {   // Loop until end of string
        UART_Write_Char(*str);
        str++;               // Move to next character
    }
}

// Wait and read one character from UART
char UART_Read_Char(void) {
    while (!PIR1bits.RCIF);  // Wait until data is received
    return RCREG;            // Return received character
}

// Read a full string until Enter (\r or \n) is pressed
void UART_Read_String(char *buffer) {
    int i = 0;
    char c;
    
    while (1) {
        c = UART_Read_Char();
        
        // Echo the character back to the Virtual Terminal so the user sees what they type
        UART_Write_Char(c);
        
        // Stop reading if Enter is pressed or buffer is full
        if (c == '\r' || c == '\n') {
            break;
        }
        
        if (i < MAX_BUFFER - 1) {
            buffer[i++] = c;
        }
    }
    buffer[i] = '\0'; // Null terminate the string
    UART_Write_Char('\r'); // Return carriage
    UART_Write_Char('\n'); // Return line
}

// ============================================================================
// LOGIC FUNCTIONS
// ============================================================================

// Check if a character is a vowel (Returns 1 if Vowel, 0 if Not)
int Is_Vowel(char c) {
    c = tolower(c); // Convert to lowercase to handle 'A' and 'a' the same way
    if (c == 'a' || c == 'e' || c == 'i' || c == 'o' || c == 'u') {
        return 1;
    }
    return 0;
}

// ============================================================================
// MAIN PROGRAM
// ============================================================================
void main(void) {
    char inputBuffer[MAX_BUFFER]; 
    char outputBuffer[30];
    int vowelCount = 0;
    
    UART_Init();             // Start UART peripheral
    
    UART_Write_String("\r\n--- Vowel Counter Ready ---\r\n");
    UART_Write_String("Enter a string to count vowels:\r\n> ");
    
    while (1) {
        // 1. Read string from Virtual Terminal
        UART_Read_String(inputBuffer);
        
        // 2. Calculate vowels
        vowelCount = 0;
        for (int i = 0; inputBuffer[i] != '\0'; i++) {
            if (Is_Vowel(inputBuffer[i])) {
                vowelCount++;
            }
        }
        
        // 3. Format and send the result
        sprintf(outputBuffer, "Vowels found: %d\r\n", vowelCount);
        UART_Write_String(outputBuffer);
        
        // 4. Prompt again
        UART_Write_String("\nEnter another string:\r\n> ");
    }
}
